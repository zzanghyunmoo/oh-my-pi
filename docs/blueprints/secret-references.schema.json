{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zzanghyunmoo/oh-my-pi/docs/blueprints/secret-references.schema.json",
  "title": "oh-my-pi secret blueprint references",
  "description": "Commit-safe metadata for environment toggles, secret references, OAuth state boundaries, and package/profile intents. Values that can authenticate, identify a private endpoint, or capture local state must not appear in documents that use this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profile",
    "environment",
    "oauthStateBoundaries",
    "localOnlyPaths",
    "recreateOnAnotherMachine"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "packageIntents"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "packageIntents": {
          "type": "array",
          "items": { "$ref": "#/$defs/packageIntent" },
          "uniqueItems": true
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toggles", "configuration", "secrets"],
      "properties": {
        "toggles": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentEntry" },
          "uniqueItems": true
        },
        "configuration": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentEntry" },
          "uniqueItems": true
        },
        "secrets": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentEntry" },
          "uniqueItems": true
        }
      }
    },
    "oauthStateBoundaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/oauthStateBoundary" },
      "uniqueItems": true
    },
    "localOnlyPaths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason", "commitPolicy"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "commitPolicy": { "const": "never-commit" }
        }
      },
      "uniqueItems": true
    },
    "recreateOnAnotherMachine": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "$defs": {
    "packageIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "installSpec", "intent", "commitPolicy"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "installSpec": { "type": "string", "minLength": 1 },
        "intent": {
          "type": "string",
          "enum": ["core-profile", "optional-profile", "manual-signal"]
        },
        "commitPolicy": {
          "type": "string",
          "enum": ["committed-reference-only", "local-install-state-only"]
        },
        "notes": { "type": "string" }
      }
    },
    "environmentEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "capability",
        "kind",
        "requiredWhen",
        "valueBoundary",
        "localValueSource",
        "commitPolicy"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "capability": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["toggle", "endpoint", "api-key", "oauth-state"]
        },
        "requiredWhen": { "type": "string", "minLength": 1 },
        "valueBoundary": {
          "type": "string",
          "enum": ["boolean-toggle", "local-endpoint", "secret-token", "oauth-state-reference"]
        },
        "localValueSource": { "type": "string", "minLength": 1 },
        "commitPolicy": {
          "type": "string",
          "enum": ["name-and-intent-only", "never-commit-value"]
        },
        "notes": { "type": "string" }
      }
    },
    "oauthStateBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "capability",
        "loginCommand",
        "stateBoundary",
        "commitPolicy",
        "recreateBy"
      ],
      "properties": {
        "service": { "type": "string", "enum": ["linear", "notion"] },
        "capability": { "type": "string", "minLength": 1 },
        "loginCommand": { "type": "string", "minLength": 1 },
        "stateBoundary": { "type": "string", "minLength": 1 },
        "commitPolicy": { "const": "never-commit-oauth-state" },
        "recreateBy": { "type": "string", "minLength": 1 }
      }
    }
  }
}
